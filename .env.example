# Variables de entorno — Sala 28
# Copia este archivo como .env y rellena los valores reales.
# .env nunca se sube al repositorio.

# Supabase
# Encuéntralos en: https://supabase.com/dashboard → proyecto → Settings → API
NUXT_SUPABASE_URL=https://tu-proyecto.supabase.co
NUXT_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Resend — para emails transaccionales
# Crea una API key en: https://resend.com/api-keys
# El dominio sala28.es debe estar verificado en Resend antes de usarlo como remitente
NUXT_RESEND_API_KEY=re_...

# Email del equipo que recibe notificaciones de nuevas solicitudes
NUXT_TEAM_EMAIL=hola@sala28.es

# URL pública del sitio (usada para OG tags y canonical)
NUXT_PUBLIC_SITE_URL=https://sala28.es

# Plausible Analytics — dominio tal como está en tu dashboard de Plausible
# Déjalo vacío en desarrollo para no contaminar las métricas
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=sala28.es
